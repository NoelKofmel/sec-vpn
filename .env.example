# Backend
DATABASE_URL=postgresql+asyncpg://secvpn:secvpn_dev@localhost:5432/secvpn
REDIS_URL=redis://localhost:6379
SECRET_KEY=change-this-to-a-random-32-char-string
LOG_LEVEL=INFO
DEBUG=true

# mTLS — backend→node-agent client credentials
# Generate with: ./scripts/gen-mtls-certs.sh
MTLS_CA_CERT=/certs/ca.crt
MTLS_CLIENT_CERT=/certs/client.crt
MTLS_CLIENT_KEY=/certs/client.key

# Health check interval in seconds
HEALTH_CHECK_INTERVAL=60

# Node agent
WG_INTERFACE=wg0
MTLS_SERVER_CERT=/certs/server.crt
MTLS_SERVER_KEY=/certs/server.key
